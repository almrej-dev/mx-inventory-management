datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum ItemType {
  RAW_MATERIAL
  SEMI_FINISHED
  FINISHED
  PACKAGING

  @@map("item_type")
}

enum TransactionType {
  RECEIVE
  SALE_DEDUCTION
  WASTE
  ADJUSTMENT

  @@map("transaction_type")
}

model Item {
  id           Int       @id @default(autoincrement())
  sku          String    @unique
  name         String
  type         ItemType
  category     String?
  unitWeightMg Int       @map("unit_weight_mg")
  cartonSize   Int       @map("carton_size")
  costCentavos Int       @map("cost_centavos")
  stockQty     Int       @default(0) @map("stock_qty")
  minStockQty  Int       @default(0) @map("min_stock_qty")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  transactions InventoryTransaction[]

  recipeIngredients RecipeIngredient[] @relation("RecipeParent")
  usedInRecipes     RecipeIngredient[] @relation("RecipeChild")

  @@map("items")
}

model InventoryTransaction {
  id           Int             @id @default(autoincrement())
  itemId       Int             @map("item_id")
  type         TransactionType
  quantity     Int
  referenceId  String?         @map("reference_id")
  notes        String?
  costCentavos Int?            @map("cost_centavos")
  createdAt    DateTime        @default(now()) @map("created_at")
  createdBy    String          @map("created_by")

  item Item @relation(fields: [itemId], references: [id])

  @@index([itemId, createdAt])
  @@map("inventory_transactions")
}

model RecipeIngredient {
  id             Int @id @default(autoincrement())
  parentItemId   Int @map("parent_item_id")
  childItemId    Int @map("child_item_id")
  quantityMg     Int @map("quantity_mg")
  quantityPieces Int @default(0) @map("quantity_pieces")

  parentItem Item @relation("RecipeParent", fields: [parentItemId], references: [id])
  childItem  Item @relation("RecipeChild", fields: [childItemId], references: [id])

  @@unique([parentItemId, childItemId])
  @@map("recipe_ingredients")
}

model Profile {
  id        String   @id @db.Uuid
  fullName  String   @map("full_name")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("profiles")
}
