
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ItemType {
  RAW_MATERIAL
  SEMI_FINISHED
  FINISHED
  PACKAGING

  @@map("item_type")
}

enum UnitType {
  grams
  pcs

  @@map("unit_type")
}

enum TransactionType {
  RECEIVE
  SALE_DEDUCTION
  WASTE
  ADJUSTMENT

  @@map("transaction_type")
}

model Item {
  id           Int      @id @default(autoincrement())
  sku          String   @unique
  name         String
  type         ItemType
  unitType     UnitType @default(grams) @map("unit_type")
  category     String?
  unitWeightMg Int      @map("unit_weight_mg")
  cartonSize   Int      @map("carton_size")
  costCentavos        Int      @map("cost_centavos")
  costPerCartonCentavos Int    @default(0) @map("cost_per_carton_centavos")
  stockQty     Int      @default(0) @map("stock_qty")
  minStockQty  Int      @default(0) @map("min_stock_qty")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  transactions      InventoryTransaction[]
  recipeIngredients RecipeIngredient[]     @relation("RecipeParent")
  usedInRecipes     RecipeIngredient[]     @relation("RecipeChild")
  salesLines        SalesLine[]

  @@map("items")
}

model InventoryTransaction {
  id           Int             @id @default(autoincrement())
  itemId       Int             @map("item_id")
  type         TransactionType
  quantity     Int
  referenceId  String?         @map("reference_id")
  notes        String?
  costCentavos Int?            @map("cost_centavos")
  createdAt    DateTime        @default(now()) @map("created_at")
  createdBy    String          @map("created_by")

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, createdAt])
  @@map("inventory_transactions")
}

model RecipeIngredient {
  id             Int @id @default(autoincrement())
  parentItemId   Int @map("parent_item_id")
  childItemId    Int @map("child_item_id")
  quantityMg     Int @map("quantity_mg")
  quantityPieces Int @default(0) @map("quantity_pieces")

  parentItem Item @relation("RecipeParent", fields: [parentItemId], references: [id], onDelete: Cascade)
  childItem  Item @relation("RecipeChild", fields: [childItemId], references: [id], onDelete: Cascade)

  @@unique([parentItemId, childItemId])
  @@map("recipe_ingredients")
}

model SalesUpload {
  id           Int      @id @default(autoincrement())
  fileName     String?  @map("file_name")
  source       String   @default("upload")
  status       String   @default("pending")
  totalLines   Int      @default(0) @map("total_lines")
  matchedLines Int      @default(0) @map("matched_lines")
  saleDate     DateTime @map("sale_date")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  createdBy    String   @map("created_by")

  lines SalesLine[]

  @@map("sales_uploads")
}

model SalesLine {
  id                Int     @id @default(autoincrement())
  uploadId          Int     @map("upload_id")
  itemId            Int     @map("item_id")
  productName       String  @map("product_name")
  quantity          Int
  unitPriceCentavos Int?    @map("unit_price_centavos")
  deducted          Boolean @default(false)

  upload SalesUpload @relation(fields: [uploadId], references: [id])
  item   Item        @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("sales_lines")
}

model Profile {
  id        String   @id @db.Uuid
  fullName  String   @map("full_name")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("profiles")
}

// Managed by Supabase SQL — defined here so Prisma does not drop it.
enum AppRole {
  admin
  staff
  viewer

  @@map("app_role")
}

// Managed by Supabase SQL — defined here so Prisma does not drop this table.
// Do not use this model for queries; use the Supabase client instead.
model UserRole {
  userId String  @map("user_id") @db.Uuid
  role   AppRole @default(viewer)

  @@id([userId, role])
  @@map("user_roles")
}

enum AuditEntityType {
  ITEM
  PRODUCT

  @@map("audit_entity_type")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE

  @@map("audit_action")
}

model AuditLog {
  id         Int             @id @default(autoincrement())
  entityType AuditEntityType @map("entity_type")
  entityId   Int             @map("entity_id")
  entityName String          @map("entity_name")
  entitySku  String          @map("entity_sku")
  action     AuditAction
  changes    Json?
  createdBy  String          @map("created_by")
  createdAt  DateTime        @default(now()) @map("created_at")

  @@index([entityType, createdAt])
  @@map("audit_logs")
}

model ZReading {
  id            Int      @id @default(autoincrement())
  storeName     String?  @map("store_name")
  receiptNumber String?  @map("receipt_number")
  receiptDate   DateTime @map("receipt_date")
  subtotal      Int      @default(0)
  tax           Int      @default(0)
  total         Int      @default(0)
  paymentMethod String?  @map("payment_method")
  imageUrl      String   @map("image_url")
  notes         String?
  status        String   @default("pending")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  createdBy     String   @map("created_by") @db.Uuid

  lines ZReadingLine[]

  @@map("z_readings")
}

model ZReadingLine {
  id                Int    @id @default(autoincrement())
  readingId         Int    @map("reading_id")
  productName       String @map("product_name")
  quantity          Int    @default(1)
  unitPriceCentavos Int    @default(0) @map("unit_price_centavos")
  lineTotalCentavos Int    @default(0) @map("line_total_centavos")

  reading ZReading @relation(fields: [readingId], references: [id], onDelete: Cascade)

  @@index([readingId])
  @@map("z_reading_lines")
}
